{
  "version": 2,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*).rar",
      "headers": [
        {
          "key": "Content-Disposition",
          "value": "attachment"
        },
        {
          "key": "Content-Type",
          "value": "application/octet-stream"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/ilgaz-launcher.RAR",
      "destination": "/ilgaz-launcher.rar"
    }
  ]
}
