{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/launcher",
      "destination": "/launcher/index.html"
    },
    {
      "source": "/launcher/:path*",
      "destination": "/launcher/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/launcher/ilgaz-launcher.RAR",
      "headers": [
        {
          "key": "Content-Disposition",
          "value": "attachment"
        }
      ]
    }
  ]
}
