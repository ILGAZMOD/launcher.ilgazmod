{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/launcher",
      "destination": "/launcher/index.html"
    },
    {
      "source": "/launcher/:path*",
      "destination": "/launcher/:path*"
    },
    {
      "handle": "filesystem"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
